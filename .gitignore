# Nextflow working directory (per-task scratch space) and session artifacts.
# Never meant to be versioned; regenerated by every pipeline run.
work/
.nextflow/
.nextflow.log*

# Large source/intermediate data. Reference genome, GTF, and truth sets are
# regenerated by scripts/fetch_reference_data.sh; the remote-sliced BAMs and
# WES exome-intersected BAMs are regenerated by re-running the pipelines
# (see README "How to run each pipeline"). Small, non-regenerable pipeline
# outputs actually used by the notebooks (filtered VCFs, CNVkit segments,
# prepared truth-set VCFs) are intentionally NOT excluded here.
data/raw/
data/reference/
data/processed/wes/*.bam
data/processed/wes/*.bam.bai

# R session artifacts (notebook 3)
.RData
.Rhistory

# Local AI-assistant tooling config, not part of the project deliverable
.claude/
