/*
 * Root Nextflow configuration for the melanoma WES + WGS + bulk RNA-seq portfolio project.
 *
 * Run every pipeline from the repository root so this file is picked up automatically, e.g.
 *   nextflow run pipelines/wes/main.nf -profile conda
 * not
 *   cd pipelines/wes && nextflow run main.nf
 * Nextflow loads nextflow.config from the current working directory in addition to the
 * directory the entry script lives in, so launching from the root is what makes the shared
 * params, resource limits, and profiles below apply to all three pipelines.
 *
 * DSL2 is the default since Nextflow 22.03, so it is not declared explicitly here; if you're
 * on an older Nextflow this pipeline will not work correctly, hence nextflowVersion below.
 */

params {
    // ---- output locations ----
    outdir         = "results"
    reference_dir  = "data/reference"
    raw_dir        = "data/raw"
    processed_dir  = "data/processed"

    // ---- reference genome: GRCh37, chr9 + chr20 only, bare numeric contig names ----
    // Matches the COLO829T/COLO829BL BAM header exactly (@SQ SN:9, SN:20), confirmed by
    // reading the header directly rather than assuming, see README for how that was checked.
    ref_fasta_chr9  = "${params.reference_dir}/Homo_sapiens.GRCh37.dna.chromosome.9.fa.gz"
    ref_fasta_chr20 = "${params.reference_dir}/Homo_sapiens.GRCh37.dna.chromosome.20.fa.gz"
    gtf             = "${params.reference_dir}/gencode.v19.annotation.gtf.gz"

    // ---- transcriptome reference for Module 3's Salmon quantification ----
    // Deliberately genome-wide, not restricted to chr9/chr20: RNA-seq differential
    // expression and GSEA/GO need real, whole-transcriptome expression, unlike the
    // WES/WGS modules. Protein-coding + lncRNA transcripts only (not every GENCODE
    // biotype), and no genome decoy sequence, both disk-driven simplifications
    // documented in modules/quantify.nf.
    pc_transcripts_fa    = "${params.reference_dir}/gencode.v19.pc_transcripts.fa.gz"
    lncrna_transcripts_fa = "${params.reference_dir}/gencode.v19.lncRNA_transcripts.fa.gz"

    // ---- COLO829 truth sets (see README for provenance and licensing of each) ----
    truth_sv_vcf      = "${params.reference_dir}/truth_sets/truthset_somaticSVs_COLO829.vcf"
    truth_snv_txt     = "${params.reference_dir}/truth_sets/Truthset_SNV_COLO829.txt"
    truth_indel_txt   = "${params.reference_dir}/truth_sets/Truthset_Indel_COLO829.txt"
    cnv_reference_cna = "${params.reference_dir}/cnv_reference/COLO829.somatic.bicseq.cna"

    // ---- remote source BAMs, ENA study PRJEB27698 ----
    // These are 196.8GB (tumor) and 71.1GB (normal) in full. They are never downloaded
    // whole: modules/slice_remote_bam.nf uses samtools to pull only chr9+chr20 directly
    // over HTTPS range requests, confirmed to work against these exact URLs (206 Partial
    // Content, correct Content-Range) before this pipeline was written.
    tumor_bam_url  = "https://ftp.sra.ebi.ac.uk/vol1/run/ERR275/ERR2752450/COLO829T_dedup.realigned.bam"
    normal_bam_url = "https://ftp.sra.ebi.ac.uk/vol1/run/ERR275/ERR2752449/COLO829R_dedup.realigned.bam"

    // ---- germline population resource for Mutect2, 1000 Genomes Phase 3 (GRCh37) ----
    // Added after a real finding: an initial WES run with no germline resource at all
    // showed most Mutect2 PASS calls had no relationship to the truth set, consistent
    // with germline sites being misclassified as somatic. See
    // modules/prepare_reference.nf's PREPARE_GERMLINE_RESOURCE for the full story and
    // why 1000 Genomes rather than gnomAD (gnomAD's own resource is multi-GB even before
    // subsetting). Confirmed HTTPS range-request support before using these URLs, the
    // same check applied to the COLO829 BAMs themselves.
    germline_resource_chr9_url  = "https://ftp.1000genomes.ebi.ac.uk/vol1/ftp/release/20130502/ALL.chr9.phase3_shapeit2_mvncall_integrated_v5b.20130502.genotypes.vcf.gz"
    germline_resource_chr20_url = "https://ftp.1000genomes.ebi.ac.uk/vol1/ftp/release/20130502/ALL.chr20.phase3_shapeit2_mvncall_integrated_v5b.20130502.genotypes.vcf.gz"

    // ---- chromosome scope ----
    // Bare numeric to match the BAM/reference contig naming above. chr20 is included as a
    // clean, moderate-size, low-repeat-content chromosome; chr9 is included for CDKN2A, a
    // frequently altered melanoma tumor suppressor. Both are whole chromosomes, not just
    // gene-proximal windows, per the project brief. If disk space is tight, the single
    // lowest-effort way to shrink this is to change this one line to "20" and drop chr9,
    // or to restrict chr9 to a CDKN2A-proximal region in modules/slice_remote_bam.nf.
    chromosomes = "9,20"

    tumor_sample_name  = "COLO829T"
    // "COLO829BL" is this cell line's common name in the literature, but it is not the
    // sample name actually baked into ERR2752449's BAM read groups: GATK's own error
    // when this mismatch was hit ("Sample COLO829BL is not in BAM header:
    // [COLO829R, COLO829T]") confirmed the real internal SM: tag is "COLO829R". ENA's
    // own filereport metadata for this run had already hinted at this
    // (sample_alias: "COLO829R", noted during this project's initial data-sizing pass),
    // but that was only cross-checked against the tumor BAM's read groups at the time,
    // not the normal's, which is how this went unnoticed until Mutect2 actually ran.
    // This value has to match the BAM's internal sample name exactly, since it is used
    // both for -normal in Mutect2 and for every output file's naming.
    normal_sample_name = "COLO829R"

    // ---- coverage downsampling for the chr9+chr20 slice ----
    // Added after real disk pressure during development (930GB used / 423MB free on a
    // 931GB drive, unrelated pre-existing usage plus this project's own ~19GB) showed
    // the native-depth whole-chromosome slice was too large to comfortably coexist with
    // everything else on this machine. Downsampling to still-standard, commonly-used
    // WGS depths (30x tumor, 20x normal, versus this sample's real native ~98x/~37x)
    // cuts the combined chr9+chr20 slice from ~17-18GB to roughly 6.5GB. This is a real,
    // deliberate change from the project's original "whole chromosome, native depth"
    // decision, not a silent shortcut: lower depth, particularly in the normal sample,
    // will somewhat reduce recall in the benchmarking notebooks versus native depth,
    // since fewer supporting reads means some true variants fall below a caller's
    // confidence threshold. Set downsample_enabled = false to restore full native depth
    // once more disk headroom is available. The native depth values below are this
    // exact sample's real, measured values (base_count / genome length from its own ENA
    // filereport metadata, checked during this project's initial data-sizing pass), not
    // generic WGS assumptions.
    downsample_enabled  = true
    tumor_native_depth  = 98.0
    normal_native_depth = 37.0
    target_tumor_depth  = 30.0
    target_normal_depth = 20.0

    // ---- RNA-seq module: TCGA-SKCM open counts (default) and an opt-in FASTQ demo ----
    // 60 per group x 2 groups (Primary Tumor, Metastatic) = up to 120 files x ~4.2MB =~
    // 500MB total: a real download, but comfortably inside the 2GB auto-proceed
    // threshold even summed across every file.
    tcga_max_per_group = 60

    // Off by default: every individual FASTQ file below is several GB, well over the
    // 2GB threshold that requires explicit confirmation before downloading. Enable with
    // `--run_fastq_demo true` only once you're ready for that download; see
    // pipelines/rnaseq/main.nf for what this path is and is not (a pipeline-mechanics
    // demonstration, not a powered differential-expression comparison on its own).
    run_fastq_demo = false

    // The two smallest samples (by combined R1+R2 size) in GSE78220 (Hugo et al. 2016,
    // melanoma anti-PD-1 pretreatment biopsies), sized against ENA's filereport API
    // before being hardcoded here: SRR3184285/Pt8 (~4.46GB combined) and
    // SRR3184294/Pt20 (~5.76GB combined).
    fastq_demo_samples = [
        [id: 'SRR3184285_Pt8',
         r1: 'https://ftp.sra.ebi.ac.uk/vol1/fastq/SRR318/005/SRR3184285/SRR3184285_1.fastq.gz',
         r2: 'https://ftp.sra.ebi.ac.uk/vol1/fastq/SRR318/005/SRR3184285/SRR3184285_2.fastq.gz'],
        [id: 'SRR3184294_Pt20',
         r1: 'https://ftp.sra.ebi.ac.uk/vol1/fastq/SRR318/004/SRR3184294/SRR3184294_1.fastq.gz',
         r2: 'https://ftp.sra.ebi.ac.uk/vol1/fastq/SRR318/004/SRR3184294/SRR3184294_2.fastq.gz'],
    ]

    // ---- resource guardrails ----
    // Tuned for a personal laptop (stated hard limits: ~12GB RAM, no single step over
    // ~30 minutes without checking first), not a cluster. max_memory/max_cpus are used
    // directly below (the executor block) and are the actual ceiling this machine has,
    // not a target to scale toward.
    max_memory = 12.GB
    max_cpus   = 4
    max_time   = 8.h
}

process {
    // Static per-label resources, not scaled up on retry: on a shared cluster, a nf-core
    // style "request more memory on each retry attempt, capped at max_memory" pattern
    // makes sense, since max_memory is a cluster-wide ceiling well above any one
    // process's normal request. Here, max_memory already equals essentially all the RAM
    // this laptop has, so a process that fails at process_high's 12GB has nowhere higher
    // to retry into anyway; scaling would just mean immediately re-hitting the same
    // ceiling. Retries below are for transient failures (exit 137/140 are typically the
    // OS OOM-killer or a transient resource spike, not a fundamentally-too-small
    // allocation), not for climbing toward more memory that does not exist.
    //
    // An earlier version of this file used a shared check_max() Groovy function to
    // enforce these ceilings dynamically; Nextflow's config parser (confirmed against
    // 26.04.4) rejects top-level function definitions in nextflow.config, so the
    // ceilings are simply respected directly in the static values below instead.
    cpus   = 1
    memory = 2.GB
    time   = 20.min

    withLabel: process_single {
        cpus   = 1
        memory = 1.GB
        time   = 20.min
    }
    withLabel: process_low {
        cpus   = 2
        memory = 4.GB
        time   = 30.min
    }
    withLabel: process_medium {
        cpus   = 4
        memory = 8.GB
        time   = 1.h
    }
    withLabel: process_high {
        // Pinned at the user's stated 12GB ceiling, not higher. Mutect2, Manta, and the
        // BAM-slicing step use this label; each is documented at the point of use with
        // why it needs to be here rather than in process_medium.
        cpus   = 4
        memory = 12.GB
        time   = 2.h
    }

    errorStrategy = { task.exitStatus in [137, 140] ? 'retry' : 'finish' }
    maxRetries    = 2
}

executor {
    name   = 'local'
    cpus   = params.max_cpus
    memory = params.max_memory
}

// Execution reports: enabled by default specifically so RAM/CPU/time per process are
// visible while you run the heavy stages yourself. peak_rss in the trace file is the
// actual measured RAM a step used, which is the number to compare against the 12GB
// guardrail above, not just what was requested.
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,status,exit,start,duration,realtime,%cpu,peak_rss,peak_vmem'
}

profiles {
    // Recommended default: one conda environment per process, versions pinned in each
    // module's `conda` directive. Needs conda or mamba on PATH (inside WSL2 Ubuntu).
    conda {
        conda.enabled          = true
        conda.useMamba         = true
        conda.createTimeout    = '30 min'
    }

    // Alternative if conda environment solving is too slow or a package conflict shows
    // up: per-process containers instead. Docker Desktop must be running and, on
    // Windows, configured to use the WSL2 backend. Image tags in each module were picked
    // for being widely used and stable, but container registries do prune old tags
    // occasionally, so verify a tag still resolves if a pull fails.
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    // Local execution is the only executor configured. This project was scoped down to
    // chr9+chr20 specifically so it fits on a single laptop; there is no SLURM/AWS Batch
    // profile because that would undercut the whole point of the resource-constrained
    // design documented in the README.
    standard {
        process.executor = 'local'
    }
}

manifest {
    name            = 'melanoma-ngs-precision-oncology'
    description     = 'WES + WGS + bulk RNA-seq somatic analysis on COLO829/COLO829BL, benchmarked against published truth sets, built in Nextflow DSL2'
    author          = 'Brandon Chua'
    homePage        = 'https://github.com/'
    mainScript      = 'pipelines/wes/main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}
